# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ===== Claude (서버 측 프록시) =====
# 클라이언트는 Anthropic API 키를 들고 있지 않는다. 대신 Supabase Edge
# Function `claude-proxy` 엔드포인트를 호출한다. 키는 그쪽 secrets로 설정.
# 비어 있으면 AI 코멘트가 fallback 메시지로 자동 전환됨.
CLAUDE_PROXY_URL=
CLAUDE_MODEL=claude-sonnet-4-6

# ===== App Encryption (DEV FALLBACK ONLY) =====
# 프로덕션에선 첫 실행 때 SecureStorage에 32바이트 랜덤 키를 만들어 쓴다.
# 시뮬레이터/유닛 테스트에서 Keychain 접근이 막혔을 때만 이 값으로 폴백.
# 비워 두어도 정상 동작. 채울 때는 base64 인코딩된 32바이트:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ===== Google Sign-In (TODO) =====
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
